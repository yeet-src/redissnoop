# Tell clangd how the BPF units are compiled (mirrors build/bpf.mk), so the
# editor resolves vmlinux.h and the __u* types instead of flagging them.
# vmlinux.h is generated by `make`, so run it once for full resolution.
CompileFlags:
  Add:
    - -target
    - bpf
    - -Isrc/bpf/include
    - -D__BPF_TRACING__
